VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key
# Opcional: Google AI Studio — Gemini en el navegador: asistente, recetas en cronograma y lista IA en Mi mercado
VITE_GEMINI_API_KEY=
# Opcional: búsqueda más fiable de vídeos en cronograma (YouTube Data API v3, cuota gratuita diaria)
VITE_YOUTUBE_API_KEY=

# Solo scripts / tests de integración (sin prefijo VITE — no van al bundle del navegador)
E2E_TEST_EMAIL=
# Usar comillas si la clave contiene # (evita que .env la trunque)
E2E_TEST_PASSWORD=
